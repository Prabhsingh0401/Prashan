# ─────────────────────────────────────────────────────────────────────────────
# Prashan / py_backend — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Security ──────────────────────────────────────────────────────────────────
INTERNAL_API_KEY=your_secret_32_char_key_here   # Must match backend/.env

# ── OpenRouter (LLM Gateway) ──────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_SITE_URL=https://prashan.co.in
OPENROUTER_SITE_NAME=Prashan

# ── LLM Model Config (override defaults in config.py) ────────────────────────
MODEL_FETCHER=nvidia/nemotron-3-ultra-550b-a55b:free
MODEL_FETCHER_FALLBACK=poolside/laguna-m.1:free
MODEL_VERIFIER=nvidia/nemotron-3-ultra-550b-a55b:free
MODEL_VERIFIER_FALLBACK=poolside/laguna-xs-2.1:free

# ── Qdrant Vector DB ──────────────────────────────────────────────────────────
QDRANT_URL=https://your-cluster-id.eu-west-2-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIs...
# QDRANT_PATH=./qdrant_db   # Uncomment for local Qdrant (dev only)

# ── Upstash Redis (TLS required — use rediss://) ──────────────────────────────
# Single URL — used by session_store.py and worker.py pub/sub
REDIS_URL=rediss://default:your_upstash_password@your-instance.upstash.io:6379

# Celery broker + result backend must also use rediss:// for Upstash
CELERY_BROKER_URL=rediss://default:your_upstash_password@your-instance.upstash.io:6379/0
CELERY_RESULT_BACKEND=rediss://default:your_upstash_password@your-instance.upstash.io:6379/0

# ── Local Redis fallback (dev only, used when REDIS_URL is not set) ───────────
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Embedding Service (Hugging Face Spaces) ───────────────────────────────────
# Used when offloading sentence-transformers from the main backend instance.
# Leave blank to use the local model (requires ≥4 GB RAM).
EMBEDDING_API_URL=https://your-hf-username-prashan-embedder.hf.space/embed